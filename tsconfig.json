{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": "./dist"
  },
  "include": [
    "src/**/*",
    "drizzle.config.ts",
    "query-surface.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
