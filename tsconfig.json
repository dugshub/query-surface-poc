{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@gen/*": [
        "./*"
      ],
      "@shared/*": [
        "./src/shared/*"
      ],
      "@modules/*": [
        "./src/modules/*"
      ],
      "@generated/*": [
        "./src/generated/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "shared/**/*",
    "schema.ts",
    "drizzle.config.ts",
    "modules/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
